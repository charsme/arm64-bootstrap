# Shared bootstrap configuration values.

export BOOTSTRAP_VERSION="v0.1.0"
export BOOTSTRAP_REPO_URL="https://github.com/charsme/arm64-bootstrap.git"
export BOOTSTRAP_BRANCH="main"

export BOOTSTRAP_LOG_DIR="/var/log/bootstrap"
export BOOTSTRAP_LOG_FILE="/var/log/bootstrap/bootstrap.log"

export DATA_MOUNT="/data"
export DATA_MARKER_FILE="/data/.mounted-data-volume"
export DATA_DOCKER_ROOT="/data/docker"

# Operator-controlled extra subdirectories created (and chowned to ubuntu)
# under /data by stage 03. Base contract dirs (docker, stacks, volumes, etc.)
# remain hardcoded in lib/disks.sh. Bash array; defaults to empty.
# Override via /etc/default/arm64-bootstrap or by editing this file.
DATA_DIRS_EXTRA=()

# Allowed Ubuntu VERSION_ID values for stage 00 preflight detect_os check.
# Bash array; defaults to the canonical target. Extend (not replace) to
# permit running on additional releases.
ALLOWED_UBUNTU_VERSIONS=("26.04")

# Docker default address pools. Two-pool layout preserves headroom for many
# user-defined networks; each pool slices a /16 into /24 subnets (256 networks).
# Adjust to avoid VPC CIDR overlap.
export DOCKER_POOL_1_BASE="172.30.0.0/16"
export DOCKER_POOL_1_SIZE="24"
export DOCKER_POOL_2_BASE="172.20.0.0/16"
export DOCKER_POOL_2_SIZE="24"

# Node.js major version installed by stage 16 from the NodeSource apt repo.
# Pinned (not floating "lts") for reproducibility; bump deliberately. 24 is the
# current active LTS line. Override via /etc/default/arm64-bootstrap or here.
export NODE_MAJOR="24"

# AWS CLI v2 version installed by stage 17 from the official zip bundle (not in
# the Ubuntu arm64 apt repo). Pinned exactly for reproducible AMIs; bump
# deliberately. See docs/operations/update-strategy.md for the bump checklist.
export AWSCLI_VERSION="2.34.60"

# Amazon CloudWatch agent version installed by stage 18 from the official S3
# .deb bundle (not in the Ubuntu arm64 apt repo). Pinned exactly for
# reproducible AMIs; bump deliberately. See docs/operations/update-strategy.md.
# Confirmed available at:
#   https://amazoncloudwatch-agent.s3.amazonaws.com/ubuntu/arm64/<ver>/amazon-cloudwatch-agent.deb
export CWAGENT_VERSION="1.300067.0b1404"

export UBUNTU_USER="ubuntu"
export DEFAULT_EDITOR="vim"
