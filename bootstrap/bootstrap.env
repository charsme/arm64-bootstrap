# Shared bootstrap configuration values.

export BOOTSTRAP_VERSION="v0.1.0"
export BOOTSTRAP_REPO_URL="https://github.com/charsme/arm64-bootstrap.git"
export BOOTSTRAP_BRANCH="main"

export BOOTSTRAP_ROOT="/opt/arm64-bootstrap"
export BOOTSTRAP_LOG_DIR="/var/log/bootstrap"
export BOOTSTRAP_LOG_FILE="/var/log/bootstrap/bootstrap.log"

export DATA_MOUNT="/data"
export DATA_MARKER_FILE="/data/.mounted-data-volume"
export DATA_DOCKER_ROOT="/data/docker"

export UBUNTU_USER="ubuntu"
export DEFAULT_EDITOR="vim"
